# Copy to .env for local overrides. Compose reads these for the app service.

# local | test | production. Guarded /api/test/* endpoints only enable when APP_ENV=test.
APP_ENV=local

# Matches the db service in docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://shop:shop@db:5432/shop

# Auth (used from Milestone 2 onward).
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Mock payment: card numbers ending in this suffix fail checkout (negative-test hook).
FAIL_CARD_SUFFIX=0000
